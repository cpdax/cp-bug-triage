# =============================================================================
# CP Bug Triage — Streamlit Secrets Template
# =============================================================================
# Copy this file to `secrets.toml` (same directory) and fill in real values.
# `secrets.toml` is in .gitignore — DO NOT commit it.
# In Streamlit Community Cloud, paste these values into the app's Secrets UI
# (Settings → Secrets) instead of committing them.
# =============================================================================


# -----------------------------------------------------------------------------
# App access
# -----------------------------------------------------------------------------
# Shared password gate. Anyone with this password can use the app.
# Pick something memorable but not guessable. Rotate periodically.
# -----------------------------------------------------------------------------

[access]
password = "REPLACE_WITH_SHARED_PASSWORD"


# -----------------------------------------------------------------------------
# Azure DevOps
# -----------------------------------------------------------------------------
# PAT scope needed: Work Items (Read) at minimum.
# Generate at: https://{org}.visualstudio.com/_usersSettings/tokens
# -----------------------------------------------------------------------------

[devops]
org_url = "https://REPLACE_WITH_ADO_ORG.visualstudio.com"
project = "REPLACE_WITH_ADO_PROJECT"
pat = "REPLACE_WITH_DEVOPS_PAT"


# -----------------------------------------------------------------------------
# Confluence
# -----------------------------------------------------------------------------
# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
# Use the email of the account that owns the token.
# -----------------------------------------------------------------------------

[confluence]
base_url = "https://procare.atlassian.net/wiki"
email = "dax.collins@childplus.com"
api_token = "REPLACE_WITH_CONFLUENCE_API_TOKEN"
cloud_id = "c10d486b-2579-435e-a10a-feb2ac4c9a29"
